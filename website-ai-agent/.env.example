# website-ai-agent environment configuration.
# Copy to .env for local development. Never commit .env.
# Every variable maps onto the Settings model (src/website_agent/config/settings.py).
# Nesting delimiter is double underscore: WA_<SECTION>__<FIELD>.

# --- LLM provider (OpenAI-compatible endpoint, design D3) ---
# Default base URL targets OpenAI. Point it at any compatible server:
#   Ollama:     http://localhost:11434/v1   (free, local)
#   Groq:       https://api.groq.com/openai/v1
#   OpenRouter: https://openrouter.ai/api/v1
WA_LLM__BASE_URL=https://api.openai.com/v1
# API key for the endpoint above. Required for hosted providers, ignored by Ollama.
# NOTE: hosted providers bill per token. Local endpoints cost nothing.
WA_LLM__API_KEY=
WA_LLM__MODEL=gpt-4o-mini
WA_LLM__TEMPERATURE=0.0
WA_LLM__MAX_OUTPUT_TOKENS=4096
WA_LLM__REQUEST_TIMEOUT_S=60
# Client-side request rate limit; 0 disables (provider 429s are still retried).
WA_LLM__REQUESTS_PER_MINUTE=60
# Send response_format=json_object for structured calls (most OpenAI-compatible servers).
WA_LLM__JSON_MODE=true
# Call mode (design D13): live | record | replay. record/replay require CASSETTE_DIR.
WA_LLM__MODE=live
WA_LLM__CASSETTE_DIR=

# --- Browser ---
WA_BROWSER__HEADLESS=true
WA_BROWSER__ACTION_TIMEOUT_MS=10000
WA_BROWSER__NAV_TIMEOUT_MS=30000

# --- Run budgets (hard stops, design D10) ---
WA_BUDGETS__MAX_STEPS=100
WA_BUDGETS__MAX_TOKENS=500000
WA_BUDGETS__MAX_USD=1.00
WA_BUDGETS__MAX_WALL_SECONDS=1800
WA_BUDGETS__MAX_CONSECUTIVE_FAILURES=5

# --- Logging ---
# Format: rich (human console) or json (machine-readable lines)
WA_LOGGING__LEVEL=INFO
WA_LOGGING__FORMAT=rich

# --- Paths ---
WA_PATHS__REPORTS_DIR=reports
WA_PATHS__CHECKPOINT_DB=reports/checkpoints.sqlite3
